            {
              "id": "prw013",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": { "editor": "<details style=\"background:#FFFFFF;border-radius:14px;overflow:hidden;margin-bottom:12px;border:1px solid rgba(0,0,0,0.06)\"><summary style=\"font-size:16px;font-weight:600;color:#1D1D1F;padding:20px 24px;cursor:pointer\">Ce să aduc la prima consultație?</summary><div style=\"padding:0 24px 20px;font-size:15px;line-height:1.7;color:#424245\">Aduceți investigațiile imagistice (RMN, CT), biletele de externare, lista medicamentelor curente și un act de identitate.</div></details><details style=\"background:#FFFFFF;border-radius:14px;overflow:hidden;margin-bottom:12px;border:1px solid rgba(0,0,0,0.06)\"><summary style=\"font-size:16px;font-weight:600;color:#1D1D1F;padding:20px 24px;cursor:pointer\">Cât durează o consultație?</summary><div style=\"padding:0 24px 20px;font-size:15px;line-height:1.7;color:#424245\">Prima consultație durează 30–45 de minute. Consultațiile de urmărire, 20–30 de minute.</div></details><details style=\"background:#FFFFFF;border-radius:14px;overflow:hidden;margin-bottom:12px;border:1px solid rgba(0,0,0,0.06)\"><summary style=\"font-size:16px;font-weight:600;color:#1D1D1F;padding:20px 24px;cursor:pointer\">Este necesar un bilet de trimitere?</summary><div style=\"padding:0 24px 20px;font-size:15px;line-height:1.7;color:#424245\">Nu este obligatoriu în regim privat. [CLIENT_CONTENT: confirmați cu clinica]</div></details><details style=\"background:#FFFFFF;border-radius:14px;overflow:hidden;border:1px solid rgba(0,0,0,0.06)\"><summary style=\"font-size:16px;font-weight:600;color:#1D1D1F;padding:20px 24px;cursor:pointer\">Cum funcționează consultația online?</summary><div style=\"padding:0 24px 20px;font-size:15px;line-height:1.7;color:#424245\">Prin videoconferință securizată. Programați prin calendarul de mai sus și veți primi un link de acces.</div></details>" },
